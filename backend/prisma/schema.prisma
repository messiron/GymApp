// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs" 
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserAgeGroup {
  UNDER_18
  BETWEEN_18_AND_30
  OVER_30
}

enum UserGender {
  MASCULINE
  FEMININE
}

enum UserInterest {
  LOSE_WEIGHT
  BUILD_MUSCULE
  IMPROVE_HEALTH
  CALISTHENICS
}

enum UserLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  isProfileCompleted        Boolean             @default(false)
  firstName                 String?
  lastName                  String?
  role                      UserRole
  ageGroup                  UserAgeGroup?
  gender                    UserGender?
  interests                 UserInterest[]
  level                     UserLevel?
  lastLoginAt               DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
}

model EmailCode {
  id             String              @id @default(cuid())
  email          String              @unique
  code           String              
  expires        Int              // In minutes
  createdAt      DateTime              @default(now())
}

model refresh_tokens {
  id             String              @id @default(cuid())
  user_id        String
  token          String
}